#!/usr/bin/env bash
# Opt-in local hook. Enable with:  git config core.hooksPath scripts/hooks
# 1) runs the neutral public guardrail; 2) if a local (git-ignored) denylist
#    exists, blocks a commit that introduces any of those terms in staged markdown.
# Contains no names itself; the term list lives only in scripts/.local/ (git-ignored).
set -uo pipefail
root="$(git rev-parse --show-toplevel)"

bash "$root/scripts/check-adrs.sh" || exit 1

denylist="$root/scripts/.local/name-denylist"
if [ -f "$denylist" ]; then
  staged=$(git diff --cached --name-only --diff-filter=ACM -- '*.md')
  if [ -n "$staged" ]; then
    while IFS= read -r term; do
      case "$term" in ''|\#*) continue;; esac
      hits=$(grep -HniE "\\b${term}\\b" $staged 2>/dev/null || true)
      if [ -n "$hits" ]; then
        echo "pre-commit blocked: local denylist term '${term}' in staged markdown:"
        echo "$hits" | sed 's/^/  - /'
        exit 1
      fi
    done < "$denylist"
  fi
fi
exit 0
